  <diagram id="data-flow" name="Match Logging Flow">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="flow-title" value="Data Flow: Logging a Match" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="400" height="40" as="geometry" />
        </mxCell>

        <!-- Step 1 -->
        <mxCell id="step1" value="1️⃣ User submits match&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;Team1: Noam + Itay&lt;br&gt;Team2: Ayal + Ari&lt;br&gt;Score: 3 - 1&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;align=center;strokeWidth=2;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="200" height="90" as="geometry" />
        </mxCell>

        <!-- Step 2 -->
        <mxCell id="step2" value="2️⃣ Validate input&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;No duplicate players&lt;br&gt;All names exist&lt;br&gt;Scores ≥ 0&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;align=center;strokeWidth=2;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="330" y="100" width="200" height="90" as="geometry" />
        </mxCell>

        <!-- Step 3 -->
        <mxCell id="step3" value="3️⃣ Save match to DB&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;INSERT into matches table&lt;br&gt;with played_at timestamp&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;align=center;strokeWidth=2;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="600" y="100" width="200" height="90" as="geometry" />
        </mxCell>

        <!-- Step 4 -->
        <mxCell id="step4" value="4️⃣ TrueSkill update&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;Load 4 players' ratings&lt;br&gt;openskill.rate([team1, team2])&lt;br&gt;Save new μ, σ, ordinal&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;align=center;strokeWidth=2;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="870" y="100" width="210" height="90" as="geometry" />
        </mxCell>

        <!-- Step 5 -->
        <mxCell id="step5" value="5️⃣ Update pair_stats&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;Noam+Itay: wins++&lt;br&gt;Ayal+Ari: matches++&lt;br&gt;Goals for/against&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;align=center;strokeWidth=2;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="1140" y="100" width="200" height="90" as="geometry" />
        </mxCell>

        <!-- Step 6 -->
        <mxCell id="step6" value="6️⃣ Return response with rating deltas&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#666&quot;&gt;Noam ▲+0.8 &amp;nbsp; Itay ▲+0.7 &amp;nbsp; Ayal ▼-0.6 &amp;nbsp; Ari ▼-0.5&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;align=center;strokeWidth=2;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="400" y="280" width="500" height="60" as="geometry" />
        </mxCell>

        <!-- Arrows -->
        <mxCell id="a12" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#333;" edge="1" parent="1" source="step1" target="step2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a23" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#333;" edge="1" parent="1" source="step2" target="step3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a34" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#333;" edge="1" parent="1" source="step3" target="step4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a45" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#333;" edge="1" parent="1" source="step4" target="step5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a56" value="" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#333;exitX=0.5;exitY=1;entryX=1;entryY=0.5;" edge="1" parent="1" source="step5" target="step6">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1240" y="310" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ═══════════════════════════════════════════ -->
        <!-- WPI CALCULATION FLOW -->
        <!-- ═══════════════════════════════════════════ -->
        <mxCell id="wpi-title" value="Weekly Power Index (WPI) Calculation — Every Monday" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="300" y="390" width="600" height="35" as="geometry" />
        </mxCell>

        <!-- WPI Components -->
        <mxCell id="wpi-skill" value="🎯 Skill Score&lt;br&gt;&lt;font style=&quot;font-size:11px;font-weight:normal;color:#555&quot;&gt;Current TrueSkill ordinal&lt;br&gt;normalized to 0-100&lt;br&gt;&lt;br&gt;&lt;/font&gt;&lt;font style=&quot;font-size:18px;color:#B60205&quot;&gt;50%&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;align=center;strokeWidth=2;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="100" y="450" width="220" height="120" as="geometry" />
